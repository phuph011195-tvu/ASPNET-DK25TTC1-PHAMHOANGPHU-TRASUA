@model List<TrasuaMON.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<h2 class="text-center fw-bold my-4 text-success">🛒 GIỎ HÀNG CỦA BẠN</h2>

@if (Model == null || !Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">Giỏ hàng đang trống!</p>
        <a href="/" class="btn btn-success fw-bold">Tiếp tục mua hàng</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-7 mb-4">
            <div class="table-responsive shadow-sm rounded border">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Món</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th>Tổng</th>
                            <th>Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@item.ImageUrl" width="40" height="40" class="me-2 rounded" style="object-fit:cover;" onerror="this.src='https://via.placeholder.com/40'">
                                    <strong class="small">@item.ProductName</strong>
                                </td>
                                <td>@string.Format("{0:N0}", item.Price)đ</td>
                                <td>@item.Quantity</td>
                                <td class="fw-bold text-danger">@string.Format("{0:N0}", item.Total)đ</td>
                                <td>
                                    <a href="/Cart/Remove?productId=@item.ProductId" class="btn btn-sm btn-outline-danger">✕</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="fw-bold mb-3">TỔNG ĐƠN HÀNG</h5>
                <div class="d-flex justify-content-between mb-3 fs-5">
                    <span>Tạm tính:</span>
                    <strong class="text-danger">@string.Format("{0:N0}", Model.Sum(x => x.Total))đ</strong>
                </div>
                <hr>
                <form action="/Cart/Checkout" method="post">
                    <h6 class="fw-bold mb-2">Thông tin giao hàng:</h6>
                    <div class="mb-2">
                        <input type="text" name="customerName" class="form-control form-control-sm" placeholder="Họ và tên..." required>
                    </div>
                    <div class="mb-2">
                        <input type="text" name="phone" class="form-control form-control-sm" placeholder="Số điện thoại..." required>
                    </div>
                    <div class="mb-3">
                        <input type="text" name="address" class="form-control form-control-sm" placeholder="Địa chỉ giao hàng..." required>
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold py-2">TIẾN HÀNH ĐẶT HÀNG & IN BILL</button>
                </form>
            </div>
        </div>
    </div>
}