@model TrasuaMON.Models.Category

@{
    ViewData["Title"] = "Thêm Danh Mục";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 p-4">
            <h4 class="fw-bold text-success mb-3">➕ THÊM DANH MỤC MỚI</h4>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên Danh Mục</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên (VD: Trà Sữa, Topping...)" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô Tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn..."></textarea>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="/Categories" class="btn btn-outline-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-success fw-bold">Lưu Danh Mục</button>
                </div>
            </form>
        </div>
    </div>
</div>