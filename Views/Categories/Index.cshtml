@model IEnumerable<TrasuaMON.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-success">📂 QUẢN LÝ DANH MỤC SẢN PHẨM</h3>
    <a href="/Categories/Create" class="btn btn-success fw-bold">+ Thêm Danh Mục Mới</a>
</div>

<div class="table-responsive shadow-sm rounded border bg-white p-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Mã ID</th>
                <th>Tên Danh Mục</th>
                <th>Mô Tả</th>
                <th class="text-end">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>#@item.Id</strong></td>
                    <td class="fw-bold text-primary">@item.Name</td>
                    <td>@item.Description</td>
                    <td class="text-end">
                        <a href="/Categories/Delete/@item.Id" onclick="return confirm('Bạn có chắc muốn xóa danh mục này?');" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>