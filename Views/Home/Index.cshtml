@model IEnumerable<TrasuaMON.Models.Product>

@{
    ViewData["Title"] = "Trang Chủ - Trà Sữa MON";
}

<!-- BANNER TRÀ SỮA NÉT CĂNG (ĐÃ CHỈNH ĐÚNG FILE background.png) -->
<div class="text-center mb-5">
    <div class="shadow-sm rounded-3 overflow-hidden border">
        <img src="/images/background.png"
             class="img-fluid w-100 d-block"
             alt="Tiệm Trà Sữa MON"
             style="max-height: 350px; object-fit: cover;" />
    </div>
</div>

<div id="menu" class="text-center mb-4">
    <small class="text-muted text-uppercase tracking-wide">MON Menu Style</small>
    <h3 class="fw-bold text-uppercase mt-1">SẢN PHẨM NỔI BẬT</h3>
    <hr class="mx-auto" style="width: 50px; height: 3px; background-color: #d4a359; opacity: 1;">
</div>

<!-- DANH SÁCH THẺ SẢN PHẨM -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-4 mb-5">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm text-center p-3">
                    <img src="@item.ImageUrl" class="card-img-top mx-auto" style="height: 180px; object-fit: contain;" alt="@item.Name" onerror="this.src='https://via.placeholder.com/180?text=TraSua'">
                    <div class="card-body d-flex flex-column justify-content-between p-2 mt-2">
                        <h6 class="card-title fw-bold text-uppercase small text-secondary">@item.Name</h6>
                        <p class="card-text text-danger fw-bold mb-2">@string.Format("{0:N0}", item.Price)đ</p>
                        <a href="/Cart/AddToCart?productId=@item.Id" class="btn btn-sm text-white fw-bold w-100" style="background-color: #d4a359;">Thêm vào giỏ</a>
                    </div>
                </div>
            </div>
        }
    }
</div>