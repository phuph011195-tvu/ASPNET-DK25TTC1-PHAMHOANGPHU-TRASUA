@model TrasuaMON.Models.Product

@{
    ViewData["Title"] = Model.Name + " - Chi Tiết";
}

<div class="container my-5">
    <div class="row g-5 bg-white p-4 rounded-4 shadow-sm">
        <div class="col-md-6 text-center d-flex align-items-center justify-content-center bg-light rounded-3" style="min-height: 400px;">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.Name" style="max-height: 380px; object-fit: contain;" />
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-between">
            <div>
                <span class="badge bg-success bg-opacity-10 text-success mb-2 px-3 py-2 fs-6">
                    @Model.Category?.Name
                </span>
                <h1 class="fw-bold text-dark mb-3">@Model.Name</h1>
                <h2 class="text-danger fw-bold mb-4">
                    @string.Format("{0:N0}", Model.Price) <span class="fs-5">đ</span>
                </h2>

                <hr class="text-muted" />

                <h5 class="fw-bold text-secondary mt-4">Mô tả món ăn:</h5>
                <p class="lead text-muted fs-6" style="line-height: 1.8;">
                    @Model.Description
                </p>
            </div>

            <div class="mt-5">
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="row g-3 align-items-center">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="col-auto">
                        <label class="fw-bold text-dark me-2">Số lượng:</label>
                        <input type="number" name="quantity" value="1" min="1" class="form-control text-center fw-bold shadow-sm" style="width: 80px;" />
                    </div>
                    <div class="col">
                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold shadow rounded-pill py-3">
                            🛒 THÊM VÀO GIỎ HÀNG
                        </button>
                    </div>
                </form>
                <a href="/#menu" class="btn btn-link text-secondary w-100 mt-3 text-decoration-none">← Quay lại danh sách menu</a>
            </div>
        </div>
    </div>
</div>