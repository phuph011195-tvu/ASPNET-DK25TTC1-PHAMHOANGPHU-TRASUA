@model IEnumerable<TrasuaMON.Models.Product>

@{
    ViewData["Title"] = "Trang Chủ - Trà Sữa MON";
}

<!-- Nhúng Font chữ Montserrat thanh lịch -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Montserrat', sans-serif;
        background-color: #ffffff;
        color: #252525;
    }

    /* === BANNER SẠCH CHỮ - GIỮ NGUYÊN ẢNH GỐC === */
    .toco-banner {
        background: url('/images/abc.png') center/cover no-repeat;
        height: 480px;
        display: flex;
        align-items: flex-end; /* Đẩy nút bấm xuống sát đáy banner */
        justify-content: center;
        text-align: center;
        position: relative;
        padding-bottom: 40px; /* Tạo khoảng cách cho nút bấm */
    }

    .toco-banner-content {
        z-index: 2;
    }
    /* Nút bấm viền mảnh màu trắng tinh tế */
    .btn-toco-outline {
        border: 2px solid #ffffff;
        color: #ffffff;
        background: rgba(0, 0, 0, 0.4); /* Thêm nền tối nhẹ cho nút để dễ nhìn trên nền ảnh */
        font-weight: 600;
        padding: 10px 28px;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        margin: 0 10px;
        border-radius: 4px;
    }

        .btn-toco-outline:hover {
            background: #ffffff;
            color: #252525;
        }

    /* === PHẦN TIÊU ĐỀ MENU === */
    .toco-custom-header {
        text-align: center;
        margin-top: 60px;
        margin-bottom: 50px;
    }

    .toco-menu-sub {
        font-size: 0.95rem;
        color: #666;
        font-weight: 500;
        margin-bottom: 5px;
    }

    .toco-menu-title {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #000000;
        position: relative;
        display: inline-block;
        padding-bottom: 15px;
    }

        .toco-menu-title::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            height: 2px;
            background-color: #d4a357;
        }

    .toco-divider-line {
        width: 120px;
        height: 1px;
        background-color: #e0e0e0;
        margin: 20px auto 0 auto;
    }

    /* === THẺ SẢN PHẨM PHẲNG === */
    .toco-product-card {
        background: #ffffff;
        border: 1px solid #eaeaea !important;
        border-radius: 0px !important;
        transition: all 0.3s ease;
        padding: 25px 15px !important;
        text-align: center;
        height: 100%;
        position: relative;
    }

        .toco-product-card:hover {
            border-color: #d4a357 !important;
        }

    .toco-img-container {
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        overflow: hidden;
    }

        .toco-img-container img {
            max-height: 240px;
            object-fit: contain;
            transition: transform 0.4s ease;
        }

    .toco-product-card:hover .toco-img-container img {
        transform: scale(1.05);
    }

    .toco-product-name {
        font-size: 0.9rem;
        font-weight: 500;
        text-transform: uppercase;
        color: #444444;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        min-height: 40px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .toco-product-price {
        font-size: 1.1rem;
        font-weight: 600;
        color: #e62117;
        margin-bottom: 15px;
    }

    .toco-btn-submit {
        background-color: #d4a357;
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 8px 20px;
        border: none;
        transition: all 0.3s ease;
        opacity: 0.85;
    }

        .toco-btn-submit:hover {
            background-color: #bfa054;
            opacity: 1;
        }

    .btn-toco-more {
        background-color: #d4a357;
        color: #ffffff;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 12px 45px;
        border: none;
        border-radius: 4px;
        transition: all 0.3s;
    }

        .btn-toco-more:hover {
            background-color: #bfa054;
            color: #ffffff;
        }
</style>

<!-- ================= HERO BANNER GIỮ NGUYÊN ẢNH GỐC ================= -->
<div class="toco-banner">
    <div class="toco-banner-content">
        <!-- Đã xóa bỏ toàn bộ text code thừa gây rối mắt -->
        <div>
            <a href="#menu" class="btn-toco-outline">Tìm hiểu thêm</a>
            <a href="#menu" class="btn-toco-outline">Đặt hàng ngay</a>
        </div>
    </div>
</div>

<!-- ================= DANH SÁCH SẢN PHẨM NỔI BẬT ================= -->
<div class="container my-5" id="menu">
    <div class="toco-custom-header">
        <div class="toco-menu-sub">MON Menu Style</div>
        <h2 class="toco-menu-title">Sản Phẩm Nổi Bật</h2>
        <div class="toco-divider-line"></div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mt-2 justify-content-center">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col" style="max-width: 300px;">
                    <div class="card toco-product-card">

                        <div class="toco-img-container">
                            @if (item != null && !string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" />
                            }
                            else
                            {
                                <img src="/images/trasua_matcha.png" alt="@item.Name" />
                            }
                        </div>

                        <h6 class="toco-product-name" title="@item.Name">
                            @item.Name.ToUpper()
                        </h6>

                        <div class="toco-product-price">
                            @string.Format("{0:N0}", item.Price)đ
                        </div>

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-2">
                            <input type="hidden" name="productId" value="@item.Id" />
                            <button type="submit" class="toco-btn-submit">
                                Thêm món
                            </button>
                        </form>

                    </div>
                </div>
            }
        }
    </div>

    <div class="text-center mt-5 pt-3">
        <button class="btn btn-toco-more shadow-sm">Xem tất cả</button>
    </div>
</div>